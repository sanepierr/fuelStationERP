# Database
DATABASE_URL=mysql://user:password@localhost:3306/fuelsync

# OAuth (Manus)
VITE_APP_ID=your-app-id
OAUTH_SERVER_URL=https://oauth.example.com

# Session security — use a long random string (e.g. openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-secret

# Session TTL in milliseconds (default: 86400000 = 24 hours)
SESSION_TTL_MS=86400000

# Webhook secret for ATG tank update endpoint (X-Webhook-Secret header)
WEBHOOK_SECRET=change-me-to-a-random-webhook-secret

# Initial admin user OpenID (auto-promoted to admin on first login)
OWNER_OPEN_ID=

# File storage (optional — Manus Forge S3)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Server port (optional, default: 3000)
PORT=3000
