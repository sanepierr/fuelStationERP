# Database
DATABASE_URL=mysql://user:password@localhost:3306/fuelsync

# Session security — use a long random string (e.g. openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-secret

# Session TTL in milliseconds (default: 86400000 = 24 hours)
SESSION_TTL_MS=86400000

# Webhook secret shared by PTS and ATG endpoints.
# Sent as: Authorization: Bearer <secret>  OR  X-Webhook-Secret: <secret>
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=change-me-to-a-random-webhook-secret

# First user to register with this email gets promoted to super_admin automatically
SUPER_ADMIN_EMAIL=your-admin@example.com

# Server port (optional, default: 3000)
PORT=3000
